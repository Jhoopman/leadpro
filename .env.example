# LeadPro environment variables
# Copy to .env and fill in real values before running locally.
# On Render: set these in the Environment tab, not in a file.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# AI model — bump this string to roll all server-side Claude calls to a new model
CLAUDE_MODEL=claude-sonnet-4-6

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...   # $97/mo Starter plan
STRIPE_PRO_PRICE_ID=price_...       # $197/mo Pro plan
STRIPE_SETUP_FEE_PRICE_ID=price_... # one-time setup fee (optional)

# ── App URL ───────────────────────────────────────────────────────────────────
# Used in email templates and Stripe success/cancel URLs.
# Must be an absolute URL — emails render in Gmail, not a browser.
# Change this when you move to a custom domain; nothing else needs updating.
APP_URL=https://app.useleadpro.net

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
# redirect_uri MUST match exactly what is registered in Google Cloud Console.
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://app.useleadpro.net/auth/google/callback

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
ALERT_EMAIL=you@example.com

# ── Twilio (SMS text-back) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE=+1...
ALERT_PHONE=+1...

# ── Google Places (prospector) ────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
